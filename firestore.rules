rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      // isAdmin can only be granted by hand in the Firebase console (the
      // Admin SDK bypasses rules); no client write may change it.
      // canHost may only be changed by an existing admin.
      allow create: if isSignedIn() && request.auth.uid == uid &&
        request.resource.data.get("isAdmin", false) != true &&
        request.resource.data.get("canHost", false) != true;
      allow update: if isSignedIn() && (
        (request.auth.uid == uid &&
          request.resource.data.get("isAdmin", false) == resource.data.get("isAdmin", false) &&
          request.resource.data.get("canHost", false) == resource.data.get("canHost", false)) ||
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["canHost"]))
      );
    }

    match /activity/{eventId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /scores/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /stats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /lessonStats/{lessonId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /lessonMatchBest/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }
  }
}
